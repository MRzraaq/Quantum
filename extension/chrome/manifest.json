{
  "manifest_version": 3,
  "name": "Quantum download manager",
  "version": "1.0",
  "description": "Intercepts downloads and sends them to your download manager",
  "permissions": [
    "downloads",
  "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quantum download manager"
  }
}